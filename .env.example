# Copy this file to .env and set real values before running Docker/Podman Compose.
# Do NOT commit .env.
#
# Runtime defaults are loaded from .env.defaults.
# Values in .env override .env.defaults.
# Leave optional values empty when unused.

# -------------------------------------------------------------------
# Required secrets for production/staging
# -------------------------------------------------------------------

# Required in production/staging to use encrypted credentials.yml.enc
RAILS_MASTER_KEY=

# Required for production: Rails secret key base for message verifiers and cookies
# Development and test environments will use a default values set in config/secrets.yml
SECRET_KEY_BASE=

# -------------------------------------------------------------------
# Runtime mode and app runtime
# Defaults exist in .env.defaults.
# Override only when needed.
# -------------------------------------------------------------------

RAILS_ENV=
RACK_ENV=
NODE_ENV=
PORT=
RAILS_MAX_THREADS=
RAILS_LOG_TO_STDOUT=
RAILS_SERVE_STATIC_FILES=
ALLOW_LOCALHOST_IN_PRODUCTION=

# -------------------------------------------------------------------
# Service endpoints
# Defaults exist in .env.defaults.
# -------------------------------------------------------------------

REDIS_URL=
SOLR_URL=
SOLR_HOST=
SOLR_PORT=
SOLR_PATH_PRODUCTION=
SOLR_PATH_STAGING=
SOLR_AUTO_COMMIT_AFTER_REQUEST_PRODUCTION=
SOLR_AUTO_COMMIT_AFTER_DELETE_REQUEST_PRODUCTION=
SOLR_AUTO_COMMIT_AFTER_REQUEST_STAGING=
SOLR_AUTO_COMMIT_AFTER_DELETE_REQUEST_STAGING=

# -------------------------------------------------------------------
# Domain configuration
# Rails also has defaults in config/initializers/constants.rb.
# -------------------------------------------------------------------

OHD_DOMAIN=
OHD_DOMAIN_DEVELOPMENT=
OHD_DOMAIN_TEST=
OHD_DOMAIN_STAGING=
OHD_DOMAIN_PRODUCTION=

# -------------------------------------------------------------------
# TLS / certbot
# Used only if the nginx/certbot compose flow is used.
# -------------------------------------------------------------------

LETSENCRYPT_DOMAIN=
LETSENCRYPT_EMAIL=

# -------------------------------------------------------------------
# Optional error tracking
# Empty disables Sentry/Bugsink error reporting.
# -------------------------------------------------------------------

SENTRY_DSN=

# -------------------------------------------------------------------
# OpenID Connect
# Use literal '\n' for line breaks when providing a PEM key in one line.
# -------------------------------------------------------------------

OIDC_SIGNING_KEY=
OIDC_ISSUER=

# -------------------------------------------------------------------
# Active Record encryption
# Only set these if the instance uses Rails Active Record encryption.
# -------------------------------------------------------------------

ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# -------------------------------------------------------------------
# Database configuration: development
# -------------------------------------------------------------------

MYSQL_HOST_DEVELOPMENT=
MYSQL_USER_DEVELOPMENT=
MYSQL_PASSWORD_DEVELOPMENT=
MYSQL_DATABASE_DEVELOPMENT=

# -------------------------------------------------------------------
# Database configuration: test
# -------------------------------------------------------------------

MYSQL_HOST_TEST=
MYSQL_USER_TEST=
MYSQL_PASSWORD_TEST=
MYSQL_DATABASE_TEST=

# -------------------------------------------------------------------
# Database configuration: staging
# -------------------------------------------------------------------

MYSQL_HOST_STAGING=
MYSQL_USER_STAGING=
MYSQL_PASSWORD_STAGING=
MYSQL_DATABASE_STAGING=

# -------------------------------------------------------------------
# Database configuration: production
# -------------------------------------------------------------------

MYSQL_HOST_PRODUCTION=
MYSQL_USER_PRODUCTION=
MYSQL_PASSWORD_PRODUCTION=
MYSQL_DATABASE_PRODUCTION=

# -------------------------------------------------------------------
# DataCite configuration: development
# -------------------------------------------------------------------

DATACITE_PREFIX_DEVELOPMENT=
DATACITE_CLIENT_ID_DEVELOPMENT=
DATACITE_PASSWORD_DEVELOPMENT=
DATACITE_URL_DEVELOPMENT=

# -------------------------------------------------------------------
# DataCite configuration: test
# -------------------------------------------------------------------

DATACITE_PREFIX_TEST=
DATACITE_CLIENT_ID_TEST=
DATACITE_PASSWORD_TEST=
DATACITE_URL_TEST=

# -------------------------------------------------------------------
# DataCite configuration: staging
# -------------------------------------------------------------------

DATACITE_PREFIX_STAGING=
DATACITE_CLIENT_ID_STAGING=
DATACITE_PASSWORD_STAGING=
DATACITE_URL_STAGING=

# -------------------------------------------------------------------
# DataCite configuration: production
# -------------------------------------------------------------------

DATACITE_PREFIX_PRODUCTION=
DATACITE_CLIENT_ID_PRODUCTION=
DATACITE_PASSWORD_PRODUCTION=
DATACITE_URL_PRODUCTION=

# -------------------------------------------------------------------
# Active Storage roots
# -------------------------------------------------------------------

STORAGE_DEV_ROOT=
STORAGE_TEST_ROOT=
STORAGE_STAGING_ROOT=
STORAGE_PROD_ROOT=
# Copy this file to .env and set real values before running docker compose.
# Do NOT commit .env.

# Optional: only needed if you want to use encrypted credentials.yml.enc
RAILS_MASTER_KEY=

# Recommended for multi-instance Docker deployments (per-instance secret)
# Use literal '\n' for line breaks when providing a PEM key in one line.
OIDC_SIGNING_KEY=

# Optional: OpenID Connect issuer URL for this instance
OIDC_ISSUER=

# Required for production: Rails secret key base for message verifiers and cookies
# Development and test environments will use a default values set in config/secrets.yml
SECRET_KEY_BASE=

# Optional: Domain for this OHD instance (overrides OHD_DOMAIN_<ENV> for current environment)
OHD_DOMAIN=

# Optional: Environment-specific domains (all have defaults in config/initializers/constants.rb)
OHD_DOMAIN_DEVELOPMENT=http://portal.oral-history.localhost:3000
OHD_DOMAIN_STAGING=https://staging.oral-history.digital
OHD_DOMAIN_PRODUCTION=https://portal.oral-history.digital
OHD_DOMAIN_TEST=http://test.portal.oral-history.localhost:47001

# Optional: Allow localhost connections in production mode
ALLOW_LOCALHOST_IN_PRODUCTION=false

# Optional Active Record encryption keys (if used by your instance)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Database configuration (environment-specific)
# Development
MYSQL_HOST_DEVELOPMENT=db
MYSQL_USER_DEVELOPMENT=ohd
MYSQL_PASSWORD_DEVELOPMENT=changeme
MYSQL_DATABASE_DEVELOPMENT=ohd_development

# Test
MYSQL_HOST_TEST=db
MYSQL_USER_TEST=root
MYSQL_PASSWORD_TEST=changeme
MYSQL_DATABASE_TEST=ohd_test

# Production
MYSQL_HOST_PRODUCTION=db
MYSQL_USER_PRODUCTION=ohd
MYSQL_PASSWORD_PRODUCTION=changeme
MYSQL_DATABASE_PRODUCTION=ohd_production

# Optional: Rails thread pool size (production)
RAILS_MAX_THREADS=5

# DataCite configuration (environment-specific)
# All have defaults in config/datacite.yml except production credentials
# Development (test environment defaults)
DATACITE_PREFIX_DEVELOPMENT=10.5072
DATACITE_CLIENT_ID_DEVELOPMENT=TIB.FUB
DATACITE_PASSWORD_DEVELOPMENT=Epub_test!
DATACITE_URL_DEVELOPMENT=https://api.test.datacite.org/dois

# Test (test environment defaults)
DATACITE_PREFIX_TEST=10.5072
DATACITE_CLIENT_ID_TEST=TIB.FUB
DATACITE_PASSWORD_TEST=Epub_test!
DATACITE_URL_TEST=https://api.test.datacite.org/dois

# Production (REQUIRED: set client_id and password; prefix and url have defaults)
DATACITE_PREFIX_PRODUCTION=10.17169
DATACITE_CLIENT_ID_PRODUCTION=
DATACITE_PASSWORD_PRODUCTION=
DATACITE_URL_PRODUCTION=https://api.datacite.org/dois

# Active Storage configuration
# Development (uses local disk by default)
STORAGE_DEV_ROOT=

# Test (uses tmp/storage by default)
STORAGE_TEST_ROOT=

# Staging (uses NFS mount by default)
STORAGE_STAGING_ROOT=/mnt/vfiler11.campus.fu-berlin.de/cedis_stream04_da/ohd/storage

# Production (uses NFS mount by default)
STORAGE_PROD_ROOT=/mnt/vfiler11.campus.fu-berlin.de/cedis_stream04_da/ohd/storage

<p>Guten Tag <%= @receiver.display_name %>,</p>

<p>Sie haben im Portal "<%= @project_name %>" folgenden Arbeitsschritt vorgenommen:</p>

<p><%= TranslationValue.for('jobs.'+@type, :de) %>:</p>

<ul>
  <li>Sammlungsname: <%= @project_name %></li>
  <% if @interview %>
    <li>Interview-ID: <%= @interview.archive_id %></li>
  <% end %>
  <% if @filename %>
    <li>Dateiname: <%= @filename %></li>
  <% end %>
  <% if @locale %>
    <li>Sprache: <%= @locale %></li>
  <% end %>
</ul>

<% if @error %>
  <p>Es gab folgende Fehlermeldung:</p>
  <%= @error.message %>
  <%= @error.backtrace[0..5] %>
<% else %>
  <p>Bitte prüfen Sie Vollständigkeit und Korrektheit der importierten Daten.</p>
<% end %>

<p>Mit freundlichen Grüßen,</p>
<p><%= @project_name %></p>

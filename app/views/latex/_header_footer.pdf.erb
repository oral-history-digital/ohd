\fancyhead{}
\fancyfoot{}
\fancyhead[L]{
<%
  logo = false
  interview ||= nil
  project ||= (interview && interview.project)
  logo_record = project.logos.where(locale: header_locale).first

  if logo_record.present?
    logo_tmp_path = File.join(Rails.root, 'tmp', 'files', "#{logo_record.file.blob.filename}")
    logo_blob_path = ActiveStorage::Blob.service.send(:path_for, logo_record.file.key)
    logo = File.file?(logo_blob_path) && File.file?(logo_tmp_path)
  end
%>
  <% if logo %>
    \includegraphics[height=12mm]{<%= "#{logo_tmp_path}" %>}
    \vspace*{0.2cm}
    \newline
  <% end %>
  \fontsize{9}{11}
  \selectfont{\textcolor{primaryColor} {<%= latex_multiscript(header_text) %> }}
  \vspace*{0.1cm}
}

<%
  institution_text = (project.institutions.where(parent_id: nil).first || project.institutions.first)&.name(header_locale)
%>

<% project ||= (interview && interview.project) %>

\fancyfoot[L]{
  \fontsize{9}{11}
  \selectfont{
    \textcolor{primaryColor} {
      \begin{minipage}[t]{0.9\textwidth}
        \raggedright
        <%= latex_footer_line(
          interview: interview,
          project: project,
          header_locale: header_locale,
          doc_type: doc_type,
        ) %>\\
        <%= latex_multiscript(TranslationValue.for('attention_to_conditions', header_locale)) %>\\
        <% if institution_text %>
          <%= latex_multiscript(institution_text) %>
        <% end %>
      \end{minipage}
    }
  }
}

\fancyfoot[R]{
  \thepage
}
